# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://127.0.0.1:3000,https://mitchell-harrison-edit-cruz.trycloudflare.com
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Encryption — Chat Master Key (AES-256-GCM)
# FIX LỖ HỔNG 5: Key được sinh ngẫu nhiên bằng openssl rand -hex 32
# ⚠️ NEVER commit this key to Git — rotate on any suspected exposure
CHAT_MASTER_KEY=37b0cd7ba809625cdc6eba0ea834e3d1763b5c3005f92fd085ec0f64d9ab2fa4

# Database
DB_HOST=localhost
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=cybersecure_db
# FIX LỖ HỔNG 8: DB_SYNC phải là false trên production để tránh mất dữ liệu
DB_SYNC=true
DB_LOGGING=true

# JWT
# FIX LỖ HỔNG 9: Secret phải ≥ 32 chars — jwt.config.ts sẽ throw error nếu thiếu/ngắn
# ⚠Ỹ  THAY BẰỞ KHI DEPLOY PRODUCTION: dùng `openssl rand -base64 48` để sinh key mạnh
JWT_SECRET=dev-jwt-secret-CHANGE-BEFORE-PRODUCTION-min32chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_SECRET=dev-refresh-secret-CHANGE-BEFORE-PRODUCTION-min32chars
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_COOKIE_NAME=refresh_token
# FIX CROSS-DOMAIN: Cloudflare tunnels dùng 2 domain khác nhau → phải dùng SameSite=none + Secure=true
# SameSite=strict sẽ block hoàn toàn cookie cross-domain → refresh_token không gửi được → login fail
JWT_COOKIE_SECURE=true
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=none

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SESSION_SECRET=dev-session-secret-change-this
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900000

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
STORAGE_TYPE=local